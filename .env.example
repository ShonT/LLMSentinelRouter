# Provider API keys (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Gemini API Keys (required for backup models)
GEMINI_BACKUP1_API_KEY=your-gemini-api-key-1-here
GEMINI_BACKUP2_API_KEY=your-gemini-api-key-2-here

# OpenRouter Configuration (optional - for free-tier models)
OPENROUTER_API_KEY=openrouter-key
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=LLMSentinelRouter

# Groq Configuration (optional - quota-based free tier)
GROQ_API_KEY=groq-api-key-placeholder

# Model identifiers (optional, with defaults)
WEAK_MODEL_ID=deepseek-reasoner
STRONG_MODEL_ID=claude-opus-4-5-20251101

# Budget & routing
MAX_COST_PER_SESSION=10.0
INITIAL_THRESHOLD=0.7
ESCALATION_RATE_LIMIT=0.05
COMPLEXITY_THRESHOLD=0.5
TARGET_ESCALATION_RATE=0.05
ROLLING_WINDOW_SIZE=20

# Cycle detection
CYCLE_DETECTION_WINDOW_SIZE=100
CYCLE_DETECTION_SIMHASH_THRESHOLD=3

# Database
DATABASE_URL=sqlite:///./data/sentinelrouter.db
DATABASE_PATH=/data/sentinelrouter.db

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FILE=./logs/sentinelrouter.log
CORS_ORIGINS=*  # Use "*" for dev, comma-separated URLs for prod (e.g., "https://example.com,https://app.example.com")

# Logging & Audit
LOG_DIR=logs
ENABLE_FILE_LOGGING=true
LOG_ROTATION_MAX_BYTES=10485760  # 10 MB
LOG_ROTATION_BACKUP_COUNT=5
LOG_RETENTION_DAYS=30

# Feature toggles
ENABLE_BUDGET_KILLSWITCH=true
ENABLE_CYCLE_DETECTION=true
ENABLE_DYNAMIC_THRESHOLD=true

# Gunicorn workers (for production)
WORKERS=2